# ArchiveIQ Configuration

# Library Settings
# Notebook library path: the directory where user document collections (notebooks) are stored.
# When running locally on Windows:
NOTEBOOK_LIBRARY_PATH=D:\Studies\Self\ArchiveIQ\data
# When running in Docker (uncomment this for Docker deployments):
# NOTEBOOK_LIBRARY_PATH=/app/data

# LLM Integration
LLM_PROVIDER=LM Studio
LLM_API_ENDPOINT=http://localhost:1234

# Log Settings
LOG_LEVEL=INFO

# Backend API
BACKEND_HOST=http://localhost
BACKEND_PORT=5678
